{
  "name": "@commercetools/mcp-essentials",
  "version": "2.4.2",
  "homepage": "https://github.com/commercetools/mcp-essentials",
  "description": "A command line tool for setting up commercetools MCP server",
  "bin": "dist/index.js",
  "files": [
    "dist/index.js",
    "LICENSE",
    "README.md",
    "VERSION",
    "package.json"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prebuild": "pnpm --filter @commercetools/agent-essentials run build",
    "dev": "concurrently -n BUILD,SERVER -c magenta,cyan \"pnpm dev:build\" \"pnpm dev:run\"",
    "dev:build": "tsup --env.NODE_ENV dev",
    "dev:run": "nodemon  dist/index.js --watch",
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "clean": "rm -rf dist",
    "lint": "eslint \"./**/*.ts*\"",
    "prettier": "prettier './**/*.{js,ts,md,html,css}' --write",
    "prettier-check": "prettier './**/*.{js,ts,md,html,css}' --check",
    "test": "jest",
    "validate": "pnpm run lint --fix && pnpm run prettier && pnpm run test"
  },
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@commercetools/agent-essentials": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "colors": "^1.4.0",
    "dotenv": "^17.4.2",
    "mcp-remote": "^0.1.38"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "commercetools"
  ],
  "author": "commercetools GmbH <info@commercetools.com> (https://commercetools.com)",
  "license": "MIT",
  "devDependencies": {
    "@eslint/compat": "^1.2.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
